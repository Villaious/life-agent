APP_NAME=local-life-agent
APP_ENV=local
DEBUG=true

DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/local_life_agent
REDIS_URL=redis://localhost:6379/0

LOCAL_LIFE_API_BASE_URL=
LOCAL_LIFE_API_KEY=
LOCAL_LIFE_TIMEOUT=15
LOCAL_LIFE_DRY_RUN=true

LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60
LLM_DRY_RUN=false

# Provider-specific optional keys. LLM_API_KEY is still supported for any provider.
OPENAI_API_KEY=
MODELSCOPE_API_KEY=
ZHIPUAI_API_KEY=
OLLAMA_API_KEY=

TOOL_SANDBOX_ENABLED=true
TOOL_AUDIT_ENABLED=true
