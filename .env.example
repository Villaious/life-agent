APP_NAME=local-life-agent
APP_ENV=local
DEBUG=true

DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/local_life_agent
REDIS_URL=redis://localhost:6379/0
BOOKING_PERSISTENCE_ENABLED=false
SESSION_CHECKPOINT_BACKEND=memory
SESSION_CHECKPOINT_TTL_SECONDS=86400

LOCAL_LIFE_API_BASE_URL=
LOCAL_LIFE_API_KEY=
LOCAL_LIFE_SANDBOX_BASE_URL=
LOCAL_LIFE_SANDBOX_API_KEY=
LOCAL_LIFE_TIMEOUT=15
LOCAL_LIFE_DRY_RUN=true

LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60
LLM_DRY_RUN=false

# 特定于提供商的可选密钥。LLM_API_KEY 仍然支持任何提供商。
OPENAI_API_KEY=
MODELSCOPE_API_KEY=
ZHIPUAI_API_KEY=
OLLAMA_API_KEY=

# High德地图(AMap) API配置
AMAP_API_KEY=
AMAP_SEARCH_RADIUS=3000
AMAP_TIMEOUT=10

TOOL_SANDBOX_ENABLED=true
TOOL_AUDIT_ENABLED=true
